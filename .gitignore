# Keep sample folders image-focused; generated metadata text files stay local.
downloads/**/*.txt

# Python caches and bytecode
__pycache__/
*.py[cod]
*$py.class

# Test and coverage output
.pytest_cache/
.coverage
coverage.xml
htmlcov/
reports/
security_scan_results.json
security_report.json
test_security_scan/
test_config.json
test_download.json

# Runtime logs
logs/
*.log

# Local assistant/tooling state
.codebuddy/
.qoder/
.serena/

# Local environment files
.env
.env.*
!.env.example
